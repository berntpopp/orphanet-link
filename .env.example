# orphanet-link — environment variables example
#
# Copy this file to .env and adjust values as needed.
# All variables use the ORPHANET_LINK_ prefix. Nested settings use __ as the
# delimiter (e.g. ORPHANET_LINK_DATA__BASE_URL for data.base_url).
#
# NOTE: GF_ORPHANET_URL is set on the ROUTER side (genefoundry-router), not here.
#       See docs/router/servers.yaml.snippet for the router integration entry.

# ---------------------------------------------------------------------------
# Server settings
# ---------------------------------------------------------------------------

# Host to bind the HTTP/unified server to.
# Default: 127.0.0.1  (change to 0.0.0.0 for Docker / remote access)
# ORPHANET_LINK_HOST=127.0.0.1

# Port to bind the HTTP/unified server to.
# Default: 8000
# ORPHANET_LINK_PORT=8000

# Transport mode: unified (HTTP REST + MCP on one port),
# http (FastAPI REST/health only; no MCP endpoint), or stdio (MCP over
# stdin/stdout for direct client use). Router deployments must use unified and
# point GF_ORPHANET_URL at the /mcp endpoint.
# Default: unified
# ORPHANET_LINK_TRANSPORT=unified

# MCP endpoint path (unified transport only; ignored by http/stdio).
# Default: /mcp
# ORPHANET_LINK_MCP_PATH=/mcp

# Exact request Host/Origin allowlists (JSON). Add the public proxy hostname in production.
# ORPHANET_LINK_ALLOWED_HOSTS=["localhost","127.0.0.1","::1"]
# ORPHANET_LINK_ALLOWED_ORIGINS=[]
# Browser deployments must also set ORPHANET_LINK_CORS_ORIGINS consistently;
# CORS response headers and request Origin validation are separate boundaries.

# Enable Uvicorn auto-reload (development only).
# Default: false
# ORPHANET_LINK_RELOAD=false

# Comma-separated CORS origins allowed for browser clients.
# Default: http://localhost:3000,http://127.0.0.1:3000
# ORPHANET_LINK_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
# ORPHANET_LINK_LOG_LEVEL=INFO

# Log format: console (human-readable) | json (structured, for log aggregators)
# Default: console
# ORPHANET_LINK_LOG_FORMAT=console

# ---------------------------------------------------------------------------
# Data store settings (ORPHANET_LINK_DATA__*)
# ---------------------------------------------------------------------------

# Directory holding the built SQLite database and Orphadata download cache.
# Default: <repo>/data  (relative to the project root)
# ORPHANET_LINK_DATA__DATA_DIR=./data

# SQLite database filename within data_dir.
# Default: orphanet.sqlite
# ORPHANET_LINK_DATA__DB_FILENAME=orphanet.sqlite

# Base URL of the Orphadata English XML scientific-knowledge files.
# Files are directly downloadable (no auth, no registration).
# Default: https://www.orphadata.com/data/xml/
# ORPHANET_LINK_DATA__BASE_URL=https://www.orphadata.com/data/xml/

# HTTP timeout in seconds for downloading an Orphadata XML file.
# Default: 300  (5 minutes; large files such as product4 can be ~50 MB)
# ORPHANET_LINK_DATA__DOWNLOAD_TIMEOUT=300

# User-Agent sent to Orphadata and GitHub Release endpoints.
# Default: orphanet-link/<version> (+https://github.com/berntpopp/orphanet-link)
# ORPHANET_LINK_DATA__USER_AGENT=orphanet-link/0.1.0 (+https://github.com/berntpopp/orphanet-link)

# ---------------------------------------------------------------------------
# Prebuilt artifact settings
# ---------------------------------------------------------------------------

# On bootstrap, try to download the prebuilt SQLite from the GitHub Release
# artifact before falling back to a local build.
# Default: true  (set to false to always build locally)
# ORPHANET_LINK_DATA__PREFER_PREBUILT=true

# GitHub owner/repo hosting the prebuilt database release assets.
# Default: berntpopp/orphanet-link
# ORPHANET_LINK_DATA__RELEASE_REPO=berntpopp/orphanet-link

# Release tag to fetch the prebuilt DB from.
# 'latest' resolves to the most recent data-* release automatically.
# Or pin to a specific release: data-1.3.42
# Default: latest
# ORPHANET_LINK_DATA__RELEASE_TAG=latest

# Ensure the database exists on first use (fetch prebuilt or build locally).
# Set to false only if you are managing the database lifecycle externally.
# Default: true
# ORPHANET_LINK_DATA__AUTO_BOOTSTRAP=true

# ---------------------------------------------------------------------------
# In-process refresh scheduler (advanced; default: disabled)
# ---------------------------------------------------------------------------

# Run an in-process background scheduler that conditionally refreshes the
# database when the unified/http transport is used. Orphanet releases are
# bi-annual; refreshing is better driven by the CI artifact pipeline and an
# external cron job rather than this in-process scheduler.
# Default: false
# ORPHANET_LINK_DATA__REFRESH_ENABLED=false

# Hours between conditional refresh checks (when refresh_enabled=true).
# Default: 168  (7 days)
# ORPHANET_LINK_DATA__REFRESH_INTERVAL_HOURS=168.0

# Random jitter (seconds) added to each refresh interval to avoid thundering
# herds in multi-replica deployments.
# Default: 600
# ORPHANET_LINK_DATA__REFRESH_JITTER_SECONDS=600

# Seconds to wait for the cross-process build lock before giving up.
# Default: 1800  (30 minutes)
# ORPHANET_LINK_DATA__BUILD_LOCK_TIMEOUT=1800

# ---------------------------------------------------------------------------
# Query cache settings
# ---------------------------------------------------------------------------

# Max entries in the in-process query cache (0 disables caching entirely).
# Default: 1024
# ORPHANET_LINK_DATA__CACHE_SIZE=1024

# Query cache TTL in seconds.
# Default: 3600  (1 hour)
# ORPHANET_LINK_DATA__CACHE_TTL=3600
