# Docker environment for orphanet-link behind Nginx Proxy Manager.
# Copy to .env.docker for the NPM compose deployment:
#
#   cp .env.docker.example .env.docker
#
# All keys are optional (the image and docker/docker-compose.npm.yml carry safe
# defaults); this file mainly pins the external NPM network and lets you tune
# data bootstrap, logging, and resource limits without editing the compose file.

# Digest-pinned application image for production overlays. Replace with the
# published release digest; this placeholder exists only so compose config can
# render without weakening docker/docker-compose.prod.yml's fail-closed guard.
ORPHANET_LINK_IMAGE=ghcr.io/berntpopp/orphanet-link@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# ---- Nginx Proxy Manager (docker/docker-compose.npm.yml) ----
# External NPM network the container joins for reverse-proxy routing.
NPM_SHARED_NETWORK_NAME=npm_default

# ---- Data bootstrap (docker/docker-compose.yml + npm.yml) ----
# Base URL for Orphadata English XML scientific-knowledge files.
# ORPHANET_LINK_DATA__BASE_URL=https://www.orphadata.com/data/xml/

# Prefer the prebuilt SQLite DB from the GitHub Release over a local build.
# ORPHANET_LINK_DATA__PREFER_PREBUILT=true

# GitHub owner/repo hosting the prebuilt database release assets.
# ORPHANET_LINK_DATA__RELEASE_REPO=berntpopp/orphanet-link

# Release tag to fetch the prebuilt DB from ('latest' or 'data-<version>').
# ORPHANET_LINK_DATA__RELEASE_TAG=latest

# ---- Server (docker/docker-compose.yml standalone) ----
# Host port published by the standalone compose file.
# ORPHANET_LINK_HOST_PORT=8000

# ---- Logging ----
LOG_LEVEL_API=INFO

# ---- NPM resource limits (optional) ----
ORPHANET_API_MEMORY_LIMIT=1g
ORPHANET_API_CPU_LIMIT=1.0
